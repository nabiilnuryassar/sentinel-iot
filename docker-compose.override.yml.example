# DEPRECATED — this file is no longer needed.
#
# The project now uses explicit per-environment compose files:
#
#   Dev:   docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d
#   Prod:  docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d
#
# The old `docker-compose.override.yml` auto-merge pattern is retired.
# See docker-compose.dev.yml for the full development configuration
# (Vite HMR on :5173, artisan serve on :8000, bind mounts).
